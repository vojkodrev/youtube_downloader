{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "YouTube Downloader",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/downloader/youtube.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Backend",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/main.go",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Frontend",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src"
        }
    ]
}
